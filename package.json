{
  "name": "janus",
  "private": true,
  "version": "0.2.7",
  "description": "Janus - AI Development Assistant",
  "author": "Janus Team <dev@janus.local>",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --packages=external --outdir=electron --format=esm --external:electron --external:node-pty && electron .",
    "build": "tsc -b && vite build && esbuild electron/main.ts electron/preload.ts --bundle --platform=node --packages=external --outdir=electron --format=esm --external:electron --external:node-pty",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview",
    "start": "tsx server/prod.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@evomap/evolver": "^1.89.0",
    "@extractus/article-extractor": "^8.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.5",
    "gpt-tokenizer": "^2.1.2",
    "lucide-react": "^0.400.0",
    "node-pty": "^1.1.0",
    "openai": "^4.55.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-virtuoso": "^4.7.11",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "simple-git": "^3.36.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron": "^1.4.38",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.janus.desktop",
    "productName": "Janus",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "shared/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3",
        "to": "node_modules/better-sqlite3"
      },
      {
        "from": "node_modules/node-pty",
        "to": "node_modules/node-pty"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
